# Plex server URL. Prefer HTTP when Plex HTTPS uses a self-signed certificate
# that does not match the NAS IP.
PLEX_BASE_URL=http://YOUR_PLEX_IP:32400

# Plex auth token.
PLEX_TOKEN=YOUR_PLEX_TOKEN

# Optional: override the curl binary, for example with a local wrapper.
# PLEX_CURL_BIN=/path/to/curl-wrapper
